{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "moduleResolution": "node",

    "ignoreDeprecations": "6.0",

    "resolveJsonModule": true,

    "skipLibCheck": true
  }
}
